    setTimeout(()=>URL.revokeObjectURL(a.href),1000); },'image/png');
};
$('btnShareImg').onclick=async()=>{
  const c=buildPoster(currentHands[activeHand]);
  c.toBlob(async b=>{
    const file=new File([b],'tesou.png',{type:'image/png'});
    if(navigator.canShare && navigator.canShare({files:[file]})){
      try{ await navigator.share({files:[file],title:'手のひらの星図'}); return; }catch(e){}
    }
    const a=document.createElement('a');a.href=URL.createObjectURL(b);a.download='tesou.png';a.click();
    setTimeout(()=>URL.revokeObjectURL(a.href),1000);
  },'image/png');
};
$('btnShareText').onclick=async()=>{
  const r=currentHands[activeHand]; const ov=r._overall||buildOverall(r);
  const text=`【手相鑑定】${EL[r.element].name}\n\n${ov.p1}\n\n${ov.p2}\n\n― 手のひらの星図で占いました`;
  if(navigator.share){ try{ await navigator.share({text}); return; }catch(e){} }
  try{ await navigator.clipboard.writeText(text); toast('コピーしました'); }
  catch(e){ toast('コピーできませんでした'); }
};
function toast(msg){const t=document.createElement('div');t.className='toast';t.textContent=msg;
  document.body.appendChild(t);setTimeout(()=>t.remove(),1800);}
 
/* =====================================================================
   4.11 履歴
   ===================================================================== */
function saveHistory(){
  try{
    const r=currentHands[activeHand];
    // thumbnail 520px jpeg
    const img=$('palmCanvas'); const s=Math.min(1,520/img.width);
    const tc=document.createElement('canvas'); tc.width=Math.round(img.width*s);tc.height=Math.round(img.height*s);
    tc.getContext('2d').drawImage(img,0,0,tc.width,tc.height);
    const thumb=tc.toDataURL('image/jpeg',0.7);
    const ov=r._overall||buildOverall(r);
    const rec={t:Date.now(),element:r.element,elName:EL[r.element].name,thumb,p1:ov.p1,p2:ov.p2};
    let arr=Store.read(); arr.unshift(rec); arr=arr.slice(0,8); Store.write(arr);
  }catch(e){/* 保存不可でも壊さない */}
  renderHistory();
}
function renderHistory(){
  let arr=[]; try{arr=Store.read();}catch(e){}
  const panel=$('historyPanel'), box=$('historyThumbs');
  if(!arr.length){panel.style.display='none';return;}
  panel.style.display='block'; box.innerHTML='';
  arr.forEach(rec=>{
    const d=document.createElement('div'); d.className='th';
    d.innerHTML=`<img src="${rec.thumb}" alt="${rec.elName}"><div class="cap">${rec.elName}</div>`;
    d.onclick=()=>openHistory(rec); box.appendChild(d);
  });
}
function openHistory(rec){
  const m=document.createElement('div'); m.className='modal';
  m.innerHTML=`<div class="panel box">
    <div class="element-badge"><div class="glyph">${EL[rec.element].glyph}</div>
      <div><div class="el-name">${EL[rec.element].name}</div>
      <div class="el-en">${new Date(rec.t).toLocaleString('ja-JP')}</div></div></div>
    <img src="${rec.thumb}" style="width:100%;border-radius:12px;border:1px solid var(--line);margin-bottom:12px">
    <div class="reading"><p>${rec.p1}</p><p>${rec.p2}</p></div>
    <div class="btnrow" style="margin-top:12px">
      <button class="btn" id="hShareText">📝 テキストで共有</button>
      <button class="btn ghost" id="hClose">閉じる</button></div></div>`;
  document.body.appendChild(m);
  m.addEventListener('click',e=>{if(e.target===m)m.remove();});
  m.querySelector('#hClose').onclick=()=>m.remove();
  m.querySelector('#hShareText').onclick=async()=>{
    const text=`【手相鑑定】${EL[rec.element].name}\n\n${rec.p1}\n\n${rec.p2}\n\n― 手のひらの星図で占いました`;
    if(navigator.share){try{await navigator.share({text});return;}catch(e){}}
    try{await navigator.clipboard.writeText(text);toast('コピーしました');}catch(e){toast('コピーできませんでした');}
  };
}
 
