async function processImage(imgEl){
  setTop('<span class="spinner"></span> 手を検出しています…');
  let lmr;
  try{
    const hl=await getHandLandmarker();
    // ensure canvas-friendly source
    lmr=hl.detect(imgEl);
  }catch(e){
    setTop('手の検出モデルを読み込めませんでした。通信環境をご確認のうえ、もう一度お試しください。');
    return;
  }
  if(!lmr || !lmr.landmarks || lmr.landmarks.length===0){
    setTop('手を認識できませんでした。手のひらを正面に向け、明るい場所で、指を軽く開いて撮り直してみてください。');
    return;
  }
  sourceImage=imgEl;
  currentHands=lmr.landmarks.map((lm,i)=>computeReading(lm, lmr.handedness?[lmr.handedness[i]?.[0]]:null));
  // 左右同判定なら 手1/手2
  if(currentHands.length===2 && currentHands[0].element===currentHands[1].element){
    currentHands.forEach((r,i)=>r.handLabel='手'+(i+1));
  } else if(currentHands.length===2 && currentHands[0].handLabel===currentHands[1].handLabel){
    currentHands.forEach((r,i)=>r.handLabel='手'+(i+1));
  }
 
  // hand toggle
  const ht=$('handToggle');
  if(currentHands.length>1){
    ht.style.display='flex'; ht.innerHTML='';
    currentHands.forEach((r,i)=>{
      const b=document.createElement('button'); b.className='btn'+(i===0?' active':'');
      b.textContent=`${r.handLabel}（${EL[r.element].name}）`;
      b.onclick=()=>{[...ht.children].forEach(c=>c.classList.remove('active'));b.classList.add('active');
        creaseMode=false;showReading(i);};
      ht.appendChild(b);
    });
  } else ht.style.display='none';
 
  viewTop.classList.add('hidden'); viewResult.classList.remove('hidden');
  window.scrollTo(0,0);
  showReading(0);
  saveHistory();
}
 
