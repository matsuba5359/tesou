function meter(label,val,min,max,bound,leftLab,rightLab,readout){
  const clamp=v=>Math.max(0,Math.min(1,(v-min)/(max-min)));
  const p=clamp(val)*100, bp=clamp(bound)*100;
  return `<div class="meter"><div class="lab"><span>${label}</span><span class="mono">${readout}</span></div>
    <div class="track"><div class="bound" style="left:${bp}%"></div><div class="dot" style="left:${p}%"></div></div>
    <div class="ends"><span>${leftLab}</span><span>${rightLab}</span></div></div>`;
}
 
