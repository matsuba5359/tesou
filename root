async function runAI(){
  const r=currentHands[activeHand];
  $('btnAI').disabled=true;
  $('aiOut').innerHTML='<span class="spinner"></span> <span class="hint">星を読んでいます…</span>';
  const el=EL[r.element];
  const F=r.fingers; const vl=v=>v==='long'?'長め':v==='short'?'短め':'標準';
  const features=`四大分類: ${el.name}(${el.en})
手のひら縦横比: ${r.aspect.toFixed(2)} / 指の長さ比: ${r.fingerRatio.toFixed(2)}
木星(人差し指): ${vl(F.jupiter)} / 土星(中指): ${vl(F.saturn)} / 太陽(薬指): ${vl(F.apollo)} / 水星(小指): ${vl(F.mercury)}
手全体の開き: ${r.handOpen==='open'?'開き気味':r.handOpen==='closed'?'閉じ気味':'標準'}（平均${r.gapAvg.toFixed(1)}度）
指の間隔: 人差し-中${r.gaps.IM}/中-薬${r.gaps.MR}/薬-小${r.gaps.RP}
指の反り: ${r.posture==='straight'?'まっすぐ':r.posture==='curved'?'しなやか':'中庸'}（弦/実長 ${r.straightAvg.toFixed(3)}）
親指の開き角度: ${r.thumbAngle.toFixed(0)}度`;
 
  const prompt=`あなたは温かく洞察力のある手相占い師です。以下は、ある人の手のひらから測定した特徴データです（写真は渡していません）。これをもとに、日本語で300〜400字・2〜3段落の鑑定文を書いてください。
条件:
- 温かく具体的に。決まり文句や占いの定型句は避ける。
- 特徴どうしのつながりを必ず一つは織り込む。
- 数値やラベルはそのまま書かず、性格描写に翻訳する。
- 断定しすぎず、前向きに締める。
- 見出しや箇条書きは使わない。地の文のみ。
 
測定データ:
${features}`;
 
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-6',max_tokens:1000,
        messages:[{role:'user',content:prompt}]})
    });
    if(!res.ok) throw new Error('http '+res.status);
    const data=await res.json();
    const text=(data.content&&data.content[0]&&(data.content[0].text||''))||'';
    if(!text.trim()) throw new Error('empty');
    $('aiOut').innerHTML=text.trim().split(/\n{2,}/).map(p=>`<p>${escapeHtml(p.trim())}</p>`).join('');
  }catch(e){
    $('aiOut').innerHTML=`<p class="hint">AI鑑定は claude.ai のプレビュー上でのみ利用できます。上のテンプレート鑑定は、そのままお楽しみいただけます。</p>`;
    $('btnAI').disabled=false;
  }
}
function escapeHtml(s){return s.replace(/[&<>]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;'}[c]));}
 
