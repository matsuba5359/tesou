let sourceImage=null;   // HTMLImageElement / canvas of the selected photo
function drawOverlay(){
  const r=currentHands[activeHand];
  const cv=$('palmCanvas'); const ctx=cv.getContext('2d');
  const img=sourceImage; if(!img) return;
  const W=img.naturalWidth||img.width, H=img.naturalHeight||img.height;
  cv.width=W; cv.height=H;
  ctx.drawImage(img,0,0,W,H);
 
  if(creaseMode && r.creaseCache && r.creaseCache.points){
    // 実際のしわ
    for(const pt of r.creaseCache.points){
      ctx.fillStyle=colorForClass(pt.c);
      ctx.beginPath();ctx.arc(pt.x*W,pt.y*H,Math.max(1.2,W*0.0016),0,Math.PI*2);ctx.fill();
    }
    setLegend(true);
  } else {
    // 参考ライン（三大線の一般カーブ）+ ランドマーク
    drawRefLines(ctx,r.lm,W,H);
    drawLandmarks(ctx,r.lm,W,H);
    setLegend(false);
  }
}
function colorForClass(c){return c==='heart'?getCss('--heart'):c==='head'?getCss('--head'):c==='life'?getCss('--life'):getCss('--other');}
function getCss(v){return getComputedStyle(document.documentElement).getPropertyValue(v).trim()||'#fff';}
function setLegend(crease){
  const L=$('legend');
  L.innerHTML=`<span><i style="background:var(--heart)"></i>感情線</span>
    <span><i style="background:var(--head)"></i>頭脳線</span>
    <span><i style="background:var(--life)"></i>生命線</span>`+
    (crease?`<span><i style="background:var(--other)"></i>その他のしわ</span>`:'');
}
function drawLandmarks(ctx,lm,W,H){
  ctx.save();
  ctx.fillStyle='rgba(242,236,255,.9)';
  const conn=[[0,1],[1,2],[2,3],[3,4],[0,5],[5,6],[6,7],[7,8],[9,10],[10,11],[11,12],
    [13,14],[14,15],[15,16],[17,18],[18,19],[19,20],[5,9],[9,13],[13,17],[0,17]];
  ctx.strokeStyle='rgba(217,184,106,.55)';ctx.lineWidth=Math.max(1,W*0.002);
  for(const [a,b] of conn){ctx.beginPath();ctx.moveTo(lm[a].x*W,lm[a].y*H);ctx.lineTo(lm[b].x*W,lm[b].y*H);ctx.stroke();}
  for(const p of lm){ctx.beginPath();ctx.arc(p.x*W,p.y*H,Math.max(1.5,W*0.0035),0,Math.PI*2);ctx.fill();}
  ctx.restore();
}
// 参考カーブ（正規化・手の座標系から近似生成）
function refCurves(lm){
  // 掌の主要点で三大線をおおまかに近似
  const P=i=>lm[i];
  const life=[P(5), mid(P(2),P(0),0.3), mid(P(1),P(0),0.55), mid(P(0),P(9),0.15)];
  const head=[mid(P(5),P(2),0.4), mid(P(0),P(9),0.45), mid(P(17),P(0),0.5)];
  const heart=[mid(P(17),P(13),0.2), mid(P(13),P(9),0.5), mid(P(9),P(5),0.6), mid(P(5),P(6),0.4)];
  return {life,head,heart};
}
function mid(a,b,t){return {x:a.x+(b.x-a.x)*t,y:a.y+(b.y-a.y)*t};}
function drawRefLines(ctx,lm,W,H){
  const c=refCurves(lm);
  const drawC=(pts,color)=>{ctx.strokeStyle=color;ctx.lineWidth=Math.max(2,W*0.005);ctx.lineCap='round';
    ctx.setLineDash([1,W*0.012]);ctx.beginPath();
    ctx.moveTo(pts[0].x*W,pts[0].y*H);
    for(let i=1;i<pts.length;i++){const pm=mid(pts[i-1],pts[i],0.5);
      ctx.quadraticCurveTo(pts[i-1].x*W,pts[i-1].y*H,pm.x*W,pm.y*H);}
    ctx.lineTo(pts[pts.length-1].x*W,pts[pts.length-1].y*H);ctx.stroke();ctx.setLineDash([]);};
  drawC(c.life,getCss('--life'));drawC(c.head,getCss('--head'));drawC(c.heart,getCss('--heart'));
}
 
/* =====================================================================
   4.7 OpenCV.js しわ検出（遅延ロード）
   ===================================================================== */
let cvLoading=null;
function loadOpenCV(){
  if(window.cv && window.cv.Mat) return Promise.resolve(window.cv);
  if(cvLoading) return cvLoading;
  cvLoading=new Promise((resolve,reject)=>{
    const s=document.createElement('script');
    s.src='https://docs.opencv.org/4.10.0/opencv.js'; s.async=true;
    s.onload=()=>{ if(window.cv && window.cv.then){ window.cv.then(m=>resolve(m)); }
      else { const iv=setInterval(()=>{if(window.cv&&window.cv.Mat){clearInterval(iv);resolve(window.cv);}},60);
             setTimeout(()=>{clearInterval(iv); window.cv&&window.cv.Mat?resolve(window.cv):reject(new Error('cv init'));},9000);} };
    s.onerror=()=>reject(new Error('opencv load failed'));
    document.head.appendChild(s);
  });
  return cvLoading;
}
async function detectCreases(r){
  const cv=await loadOpenCV();
  const img=sourceImage;
  const W0=img.naturalWidth||img.width, H0=img.naturalHeight||img.height;
  const scale=Math.min(1, CREASE.procW/W0);
  const PW=Math.round(W0*scale), PH=Math.round(H0*scale);
  const tmp=document.createElement('canvas'); tmp.width=PW;tmp.height=PH;
  tmp.getContext('2d').drawImage(img,0,0,PW,PH);
 
  let src=cv.imread(tmp), gray=new cv.Mat(), en=new cv.Mat(), bh=new cv.Mat(),
      norm=new cv.Mat(), th=new cv.Mat();
  const dels=[src,gray,en,bh,norm,th];
  try{
    cv.cvtColor(src,gray,cv.COLOR_RGBA2GRAY);
    // CLAHE → fallback equalizeHist
    try{ const clahe=new cv.CLAHE(2.0,new cv.Size(8,8)); clahe.apply(gray,en); clahe.delete(); }
    catch(e){ cv.equalizeHist(gray,en); }
    // black-hat morphology
    let k=Math.max(3,Math.round((PW+PH)/2*CREASE.kernelScale)); if(k%2===0)k++;
    const kern=cv.getStructuringElement(cv.MORPH_ELLIPSE,new cv.Size(k,k));
    cv.morphologyEx(en,bh,cv.MORPH_BLACKHAT,kern); kern.delete();
    cv.normalize(bh,norm,0,255,cv.NORM_MINMAX,cv.CV_8U);
    // Otsu (感度倍率 threshBias を適用)。th を作り直さず同じ Mat に書き込む。
    const otsu=cv.threshold(norm,th,0,255,cv.THRESH_BINARY+cv.THRESH_OTSU);
    if(Math.abs(CREASE.threshBias-1)>1e-3){
      cv.threshold(norm,th,otsu*CREASE.threshBias,255,cv.THRESH_BINARY);
    }
    // palm mask polygon [0,17,13,9,5,2,1]
    const mk=new cv.Mat.zeros(PH,PW,cv.CV_8UC1);
    const order=[0,17,13,9,5,2,1];
    const pts=[]; for(const i of order){pts.push(r.lm[i].x*PW, r.lm[i].y*PH);}
    const mat=cv.matFromArray(order.length,1,cv.CV_32SC2,pts);
    const vv=new cv.MatVector(); vv.push_back(mat);
    cv.fillPoly(mk,vv,new cv.Scalar(255));
    const er=cv.getStructuringElement(cv.MORPH_ELLIPSE,new cv.Size(Math.max(3,Math.round(k*0.8)),Math.max(3,Math.round(k*0.8))));
    cv.erode(mk,mk,er); er.delete(); mat.delete(); vv.delete();
 
    // collect points (normalized) + classify
    const ref=refCurves(r.lm);
    const points=[];
    const step=CREASE.step;
    for(let y=0;y<PH;y+=step){
      for(let x=0;x<PW;x+=step){
        if(th.ucharPtr(y,x)[0] && mk.ucharPtr(y,x)[0]){
          const nx=x/PW, ny=y/PH;
          points.push({x:nx,y:ny,c:classifyCrease(nx,ny,ref)});
        }
      }
    }
    mk.delete();
    r.creaseCache={points};
    return true;
  } finally { dels.forEach(m=>{try{m.delete();}catch(e){}}); }
}
function classifyCrease(x,y,ref){
  const near=(pts)=>{let best=1e9;for(let i=1;i<pts.length;i++){best=Math.min(best,distToSeg(x,y,pts[i-1],pts[i]));}return best;};
  const dl=near(ref.life),dh=near(ref.head),dhe=near(ref.heart);
  const m=Math.min(dl,dh,dhe);
  if(m>CREASE.nearLine) return 'other';
  return m===dl?'life':m===dh?'head':'heart';
}
function distToSeg(px,py,a,b){
  const vx=b.x-a.x,vy=b.y-a.y; const wx=px-a.x,wy=py-a.y;
  const c1=vx*wx+vy*wy; if(c1<=0)return Math.hypot(px-a.x,py-a.y);
  const c2=vx*vx+vy*vy; if(c2<=c1)return Math.hypot(px-b.x,py-b.y);
  const t=c1/c2; return Math.hypot(px-(a.x+t*vx),py-(a.y+t*vy));
}
 
