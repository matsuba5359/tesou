/* ---------- 7. 調整可能パラメータ（実写真に合わせて調整可） ---------- */
const T = {
  // 四大分類のしきい値
  palmBoundary: 1.40,   // 手のひら aspect(縦/横) の境界: これ未満=四角い / 以上=細長い
  palmMin: 1.05, palmMax: 1.80,       // メーター表示レンジ
  fingerBoundary: 0.76, // 中指長/手のひら長 の境界: 以上=指が長い
  fingerMin: 0.60, fingerMax: 0.92,   // メーター表示レンジ
  nearBoundary: 0.05,   // 境界からこの範囲内なら「隣の型も混じる」と付記(正規化)
  // 指の判定
  idxRingBand: 0.02,    // 木星(人差し)vs太陽(薬指): 差の許容帯（標準扱い）
  saturnLong: 1.11, saturnShort: 1.05, // 土星(中指)突出度
  pinkyLong: 0.00, pinkyShort: -0.045, // 水星(小指)先端の届き（掌長で正規化）
  // 間隔（開き）
  gapOpen: 16, gapClosed: 8,           // 手全体の平均角(度)
  gapWideRatio: 1.22, gapNarrowRatio: 0.78, // 各間隔の自己平均比
  // 反り
  straightStraight: 0.978, straightCurved: 0.955, // chord/arc 平均
  thumbOpen: 48        // 親指がこの角度(度)以上開けば寛容さ
};
const CREASE = {
  kernelScale: 0.030,  // ブラックハット楕円カーネル比 (0.015〜0.060)
  threshBias: 1.00,    // Otsu感度倍率 (1.4=厳しめ〜0.6=拾いすぎ)
  step: 2,             // 走査ステップ(px)
  procW: 640,          // 処理縮小幅
  nearLine: 0.03       // 参考カーブへの近さ閾値(正規化)
};
 
/* ---------- 保存層: window.storage → localStorage → memory ---------- */
const Store = (()=>{
  const KEY='tesou_history';
  let mem=null;
  function tryWinStorage(op){
    try{ if(window.storage && typeof window.storage.getItem==='function') return op(window.storage); }catch(e){}
    return undefined;
  }
  function tryLocal(op){
    try{ if(window.localStorage){ return op(window.localStorage); } }catch(e){}
    return undefined;
  }
  function read(){
    let raw;
    raw=tryWinStorage(s=>s.getItem(KEY)); if(raw!==undefined&&raw!==null) return parse(raw);
    raw=tryLocal(s=>s.getItem(KEY)); if(raw!==undefined&&raw!==null) return parse(raw);
    return mem?parse(mem):[];
  }
  function parse(r){ try{ return JSON.parse(r)||[]; }catch(e){ return []; } }
  function write(arr){
    const raw=JSON.stringify(arr);
    let ok=false;
    if(tryWinStorage(s=>{s.setItem(KEY,raw);return true;})) ok=true;
    if(!ok && tryLocal(s=>{s.setItem(KEY,raw);return true;})) ok=true;
    mem=raw; // 常にメモリにも保持
  }
  return {read,write};
})();
 
/* ---------- DOM refs ---------- */
const $=id=>document.getElementById(id);
const viewTop=$('viewTop'), viewResult=$('viewResult');
let currentHands=[];   // computed readings per hand
let activeHand=0;
let creaseMode=false;  // false=参考ライン true=実際のしわ
 
/* ---------- starfield ---------- */
(function(){
  const bg=$('starsBg'); const n=window.matchMedia('(prefers-reduced-motion:reduce)').matches?0:40;
  for(let i=0;i<n;i++){const s=document.createElement('i');
    s.style.left=Math.random()*100+'%';s.style.top=Math.random()*100+'%';
    s.style.animationDelay=(Math.random()*4)+'s';s.style.opacity=(0.2+Math.random()*0.5);
    bg.appendChild(s);}
})();
 
/* =====================================================================
   MediaPipe HandLandmarker (lazy)
   ===================================================================== */
let handLandmarker=null, hlLoading=null;
async function getHandLandmarker(){
  if(handLandmarker) return handLandmarker;
  if(hlLoading) return hlLoading;
  hlLoading=(async()=>{
    const vision=await import('https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.14');
    const {HandLandmarker,FilesetResolver}=vision;
    const resolver=await FilesetResolver.forVisionTasks('https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.14/wasm');
    handLandmarker=await HandLandmarker.createFromOptions(resolver,{
      baseOptions:{
        modelAssetPath:'https://storage.googleapis.com/mediapipe-models/hand_landmarker/hand_landmarker/float16/1/hand_landmarker.task',
        delegate:'GPU'
      },
      runningMode:'IMAGE', numHands:2
    });
    return handLandmarker;
  })();
  return hlLoading;
}
 
/* =====================================================================
   Geometry helpers （正規化座標 0..1 を基本）
   ===================================================================== */
const dist=(a,b)=>Math.hypot(a.x-b.x,a.y-b.y);
function vecAngle(u,v){
  const d=(u.x*v.x+u.y*v.y)/((Math.hypot(u.x,u.y)*Math.hypot(v.x,v.y))||1e-9);
  return Math.acos(Math.max(-1,Math.min(1,d)))*180/Math.PI;
}
function sub(a,b){return {x:a.x-b.x,y:a.y-b.y};}
// finger chains for arc/chord
const CHAINS={index:[5,6,7,8],middle:[9,10,11,12],ring:[13,14,15,16],pinky:[17,18,19,20],thumb:[1,2,3,4]};
function arcLen(lm,ch){let s=0;for(let i=1;i<ch.length;i++)s+=dist(lm[ch[i]],lm[ch[i-1]]);return s;}
function chordLen(lm,ch){return dist(lm[ch[0]],lm[ch[ch.length-1]]);}
function fingerDir(lm,ch){return sub(lm[ch[ch.length-1]],lm[ch[0]]);} // base->tip
 
/* =====================================================================
   4.x  computeReading — 1手ぶんの鑑定を計算（表示から分離）
   ===================================================================== */
function computeReading(lm, handedness){
  const wrist=lm[0];
  const palmLen=dist(lm[0],lm[9]);
  const palmWid=dist(lm[5],lm[17]);
  const aspect=palmLen/palmWid;
  const midLen=dist(lm[9],lm[12]);
  const idxLen=dist(lm[5],lm[8]);
  const ringLen=dist(lm[13],lm[16]);
  const fingerRatio=midLen/palmLen;
 
  const square=aspect<T.palmBoundary;
  const longFingers=fingerRatio>=T.fingerBoundary;
  // マッピング: 地=四角い+短い / 風=四角い+長い / 水=細長い+長い / 火=細長い+短い
  let element;
  if(square && !longFingers) element='earth';
  else if(square && longFingers) element='air';
  else if(!square && longFingers) element='water';
  else element='fire';
 
  // 境界の近さ（型が混じるか）
  const palmNear=Math.abs(aspect-T.palmBoundary)<= (T.palmMax-T.palmMin)*T.nearBoundary;
  const fingerNear=Math.abs(fingerRatio-T.fingerBoundary)<= (T.fingerMax-T.fingerMin)*T.nearBoundary;
  const nearBoundary=palmNear||fingerNear;
 
  /* ---- fingers (planets) ---- */
  const mean3=(idxLen+midLen+ringLen)/3;
  // 木星: 人差し vs 薬指
  const idxRing=(idxLen-ringLen)/mean3;
  let jupiter = idxRing>T.idxRingBand?'long':(idxRing<-T.idxRingBand?'short':'std');
  // 太陽: 木星の逆（薬指>人差し指で長い）
  let apollo = idxRing<-T.idxRingBand?'long':(idxRing>T.idxRingBand?'short':'std');
  // 土星: 中指の突出度
  const saturnRatio=midLen/((idxLen+ringLen)/2);
  let saturn = saturnRatio>T.saturnLong?'long':(saturnRatio<T.saturnShort?'short':'std');
  // 水星: 小指先端(20)が薬指第一関節(15)へ届くか、掌の縦軸へ投影
  const axis=sub(lm[9],lm[0]); const axLen=Math.hypot(axis.x,axis.y)||1e-9;
  const ux={x:axis.x/axLen,y:axis.y/axLen};
  const proj=p=>((p.x-lm[0].x)*ux.x+(p.y-lm[0].y)*ux.y);
  const pinkyReach=(proj(lm[20])-proj(lm[15]))/palmLen; // 正: 届いて超える
  let mercury = pinkyReach>=T.pinkyLong?'long':(pinkyReach<T.pinkyShort?'short':'std');
 
  /* ---- 間隔（開き） ---- */
  const dI=fingerDir(lm,CHAINS.index), dM=fingerDir(lm,CHAINS.middle),
        dR=fingerDir(lm,CHAINS.ring), dP=fingerDir(lm,CHAINS.pinky);
  const gapIM=vecAngle(dI,dM), gapMR=vecAngle(dM,dR), gapRP=vecAngle(dR,dP);
  const gapAvg=(gapIM+gapMR+gapRP)/3;
  const relGap=g=> g>gapAvg*T.gapWideRatio?'wide':(g<gapAvg*T.gapNarrowRatio?'narrow':'std');
  const gaps={IM:relGap(gapIM),MR:relGap(gapMR),RP:relGap(gapRP)};
  const handOpen = gapAvg>T.gapOpen?'open':(gapAvg<T.gapClosed?'closed':'std');
 
  // 親指の開き
  const thumbDir=fingerDir(lm,CHAINS.thumb);
  const thumbAngle=vecAngle(thumbDir, sub(lm[9],lm[0]));
  const thumbWide=thumbAngle>T.thumbOpen;
 
  /* ---- 反り（chord/arc） ---- */
  const straightness={};
  ['index','middle','ring','pinky'].forEach(k=>{
    const a=arcLen(lm,CHAINS[k]); straightness[k]= a>0? chordLen(lm,CHAINS[k])/a : 1;
  });
  const straightAvg=(straightness.index+straightness.middle+straightness.ring+straightness.pinky)/4;
  const posture = straightAvg>T.straightStraight?'straight':(straightAvg<T.straightCurved?'curved':'std');
  // 最も曲がった指
  let mostCurved=null,minS=1;
  for(const k of ['index','middle','ring','pinky']) if(straightness[k]<minS){minS=straightness[k];mostCurved=k;}
 
  /* ---- handedness label ---- */
  let handLabel='手';
  if(handedness && handedness[0]){
    const cat=handedness[0].categoryName||handedness[0].label||'';
    // MediaPipe は鏡像基準なので反転して自然な呼称に
    if(/Left/i.test(cat)) handLabel='右手';
    else if(/Right/i.test(cat)) handLabel='左手';
  }
 
  return {
    lm, handLabel,
    palmLen,palmWid,aspect,fingerRatio,
    element, square, longFingers, nearBoundary, palmNear, fingerNear,
    fingers:{jupiter,saturn,apollo,mercury},
    fingerRaw:{idxRing,saturnRatio,pinkyReach},
    gaps,gapAvg,gapIM,gapMR,gapRP,handOpen,
    thumbAngle,thumbWide,
    straightness,straightAvg,posture,mostCurved,minS,
    creaseCache:null
  };
}
 
/* =====================================================================
   文言テーブル
   ===================================================================== */
const EL={
  earth:{name:'地の手',en:'Earth',glyph:'土',opener:'四角く引き締まった手のひらに、控えめな指。あなたは地の手——足を地につけ、着実に物事を積み上げていく人です。'},
  air:{name:'風の手',en:'Air',glyph:'風',opener:'四角い土台に、すらりと伸びた指。あなたは風の手——考えることを楽しみ、言葉と発想で世界に触れていく人です。'},
  water:{name:'水の手',en:'Water',glyph:'水',opener:'細長い手のひらに、しなやかな長い指。あなたは水の手——感受性が豊かで、心の機微を敏やかに受けとる人です。'},
  fire:{name:'火の手',en:'Fire',glyph:'火',opener:'細長い手のひらに、きびきびとした指。あなたは火の手——情熱と行動力で、まわりを動かしていく人です。'}
};
const FINGER_META={
  jupiter:{glyph:'♃',name:'木星 / 人差し指',axis:'自己主張',
    long:'自信と上昇志向がしっかり。人を導く場に自然と立てる人です。',
    std:'自信と謙虚さのバランスがよく、状況に応じて前に出られます。',
    short:'控えめで気負わない構え。押しつけず、静かに信頼を集めます。'},
  saturn:{glyph:'♄',name:'土星 / 中指',axis:'責任感',
    long:'責任感と堅実さが際立ちます。締めるところをきちんと締められる人。',
    std:'まじめさと軽やかさをほどよく併せ持ちます。',
    short:'自由で柔軟。ルールより流れを大事にできる人です。'},
  apollo:{glyph:'☉',name:'太陽 / 薬指',axis:'表現',
    long:'創造性と表現力が豊か。美しいものや魅せることに惹かれます。',
    std:'表現欲と落ち着きのバランスがとれています。',
    short:'派手さより本質を重んじる、飾らない人です。'},
  mercury:{glyph:'☿',name:'水星 / 小指',axis:'伝達',
    long:'伝える力と機転に富みます。言葉で場を回せる人です。',
    std:'聞く力と話す力がほどよく調和しています。',
    short:'多くを語らず、行動と誠実さで伝えるタイプです。'}
};
 
/* =====================================================================
   総合鑑定（2段落・相互作用・重複排除）
   ===================================================================== */
function buildOverall(r){
  const el=EL[r.element];
  const F=r.fingers;
  // 目立つ指（std以外）を強い順に最大2つ
  const notable=[];
  const rank={jupiter:Math.abs(r.fingerRaw.idxRing),saturn:Math.abs(r.fingerRaw.saturnRatio-1),
              apollo:Math.abs(r.fingerRaw.idxRing),mercury:Math.abs(r.fingerRaw.pinkyReach)};
  for(const k of ['jupiter','saturn','apollo','mercury']) if(F[k]!=='std') notable.push(k);
  notable.sort((a,b)=>rank[b]-rank[a]);
  const top=notable.slice(0,2);
  const usedInInteraction=new Set();
 
  // 相互作用文（要素×指）
  let interaction='';
  if(F.saturn==='long' && r.element==='fire'){ interaction='情熱的でありながら、締めるところはきちんと締められる——火の勢いに芯が通っています。'; usedInInteraction.add('saturn');}
  else if(F.jupiter==='long' && r.element==='water'){ interaction='感受性の奥に、ぶれない意志が一本通っています。柔らかさと強さが同居する人です。'; usedInInteraction.add('jupiter');}
  else if(F.apollo==='long' && r.element==='air'){ interaction='考える力と表現する力が結びつき、アイデアをかたちにして手渡せます。'; usedInInteraction.add('apollo');}
  else if(F.mercury==='long' && r.element==='earth'){ interaction='着実さに、人を和ませる言葉が加わります。信頼と親しみを同時に集める人です。'; usedInInteraction.add('mercury');}
  else if(F.saturn==='short' && r.element==='water'){ interaction='感じたままに動ける軽やかさがあり、水の流れをせき止めません。'; usedInInteraction.add('saturn');}
  else if(F.jupiter==='long' && r.element==='fire'){ interaction='前に出る力と勢いが噛み合い、場を引っぱる推進力になります。'; usedInInteraction.add('jupiter');}
  else if(top.length){ // 汎用の相互作用
    const k=top[0]; const m=FINGER_META[k];
    interaction=`${el.name}の性質に、${m.axis}の豊かさが重なって、あなたらしい奥行きを生んでいます。`;
    usedInInteraction.add(k);
  }
 
  // 段落1: オープナー + 目立つ指（相互作用で触れた指は差し引く）+ 相互作用
  let p1=el.opener;
  if(r.nearBoundary) p1+='隣りあう型の性質も少し混じり、一面では割り切れない味わいがあります。';
  const fingerSentences=[];
  for(const k of top){
    if(usedInInteraction.has(k)) continue;
    const m=FINGER_META[k];
    fingerSentences.push(`${m.name.split(' / ')[1]}に表れた${m.axis}——${stripPeriod(FINGER_META[k][F[k]])}`);
  }
  if(fingerSentences.length) p1+=fingerSentences.join('。また、')+'。';
  if(interaction) p1+=interaction;
 
  // 段落2: 開き + 広い間隔補足 → 反り → 親指 → 締め
  let p2='';
  if(r.handOpen==='open') p2+='指がのびやかに開き、独立心と開放性を感じさせます。';
  else if(r.handOpen==='closed') p2+='指を寄せて構える様子には、慎重で内省的なまなざしがうかがえます。';
  else p2+='指の開きはほどよく、状況に応じて心を開いたり守ったりできる人です。';
  // 広い間隔の補足
  const wideGap=[];
  if(r.gaps.IM==='wide') wideGap.push('考えの独立');
  if(r.gaps.MR==='wide') wideGap.push('将来への構えの自由さ');
  if(r.gaps.RP==='wide') wideGap.push('情と行動の自立');
  if(wideGap.length) p2+='とりわけ'+wideGap.join('・')+'が広くとられています。';
  // 反り
  if(r.posture==='straight') p2+='指はまっすぐで、率直で筋を通す気質。';
  else if(r.posture==='curved'){ p2+='指はしなやかにたわみ、柔軟で相手に合わせる心づかいがあります。';
    if(r.mostCurved){ p2+=`とくに${curveAxis(r.mostCurved)}のあたりは控えめに出ます。`; } }
  else p2+='指の反りは中庸で、状況次第で率直にも柔軟にもなれます。';
  // 親指
  if(r.thumbWide) p2+='親指が大きく開くのは、寛容さと受けとめる度量の表れです。';
  p2+='——手のひらという小さな星図に、あなたの今が静かに描かれています。';
 
  return {p1,p2};
}
function stripPeriod(s){return s.replace(/。$/,'');}
function curveAxis(k){return {index:'自己主張',middle:'責任感',ring:'表現',pinky:'伝達'}[k]||'その領域';}
 
/* =====================================================================
   表示 showReading
   ===================================================================== */
function showReading(idx){
  activeHand=idx;
  const r=currentHands[idx];
  const el=EL[r.element];
 
  // element badge
  $('elBadge').innerHTML=`<div class="glyph">${el.glyph}</div>
    <div><div class="el-name">${el.name}</div><div class="el-en">${el.en} hand</div></div>`;
 
  // overall
  const ov=buildOverall(r);
  $('overallReading').innerHTML=`<p>${ov.p1}</p><p>${ov.p2}</p>`;
  r._overall=ov;
 
  // fingers grid
