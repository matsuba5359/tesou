/* =====================================================================
   4.9 ポスター生成（画像で保存/共有）
   ===================================================================== */
function buildPoster(r){
  const el=EL[r.element];
  const W=1080;
  const c=document.createElement('canvas'); const ctx=c.getContext('2d');
  // measure text first with a temp height
  c.width=W; c.height=1600;
  // background
  const grad=ctx.createLinearGradient(0,0,0,1600); grad.addColorStop(0,'#171334');grad.addColorStop(1,'#0B0A1A');
  // we render into an offscreen after computing needed height. Do two-pass:
  // pass 1 compute text lines
  const ov=r._overall||buildOverall(r);
  const bodyText=ov.p1+'\n'+ov.p2;
  ctx.font='34px "Shippori Mincho", serif';
  const maxTextW=W-160;
  const lines=wrapJP(ctx,bodyText,maxTextW,34);
  // layout heights
  const padTop=70, kanjiH=150, imgH=560, gapAfterImg=50, lineH=54, footH=120;
  const textBlockH=lines.length*lineH;
  const H=padTop+kanjiH+40+imgH+gapAfterImg+textBlockH+footH;
  c.height=H;
  // redraw bg
  const g2=ctx.createLinearGradient(0,0,0,H);g2.addColorStop(0,'#171334');g2.addColorStop(1,'#0B0A1A');
  ctx.fillStyle=g2; ctx.fillRect(0,0,W,H);
  // stars
  ctx.fillStyle='rgba(242,236,255,.7)';
  for(let i=0;i<80;i++){ctx.globalAlpha=0.2+Math.random()*0.5;ctx.beginPath();
    ctx.arc(Math.random()*W,Math.random()*(H*0.55),Math.random()*2+0.5,0,Math.PI*2);ctx.fill();}
  ctx.globalAlpha=1;
  // title
  ctx.textAlign='center'; ctx.fillStyle='#D9B86A';
  ctx.font='600 44px "Shippori Mincho", serif';
  ctx.fillText('手のひらの星図',W/2,padTop+20);
  // element kanji big
  ctx.font='600 120px "Shippori Mincho", serif'; ctx.fillStyle='#E7D3A0';
  ctx.fillText(el.glyph, W/2, padTop+kanjiH+40);
  ctx.font='500 30px "Shippori Mincho", serif'; ctx.fillStyle='#A7A1C9';
  ctx.fillText(el.name+' / '+el.en, W/2, padTop+kanjiH+80);
  // palm image
  const iy=padTop+kanjiH+120;
  const img=$('palmCanvas');
  const iw=img.width,ih=img.height; const drawW=W-200, drawH=Math.min(imgH, drawW*ih/iw);
  const dx=(W-drawW)/2, dy=iy+(imgH-drawH)/2;
  ctx.save(); roundRect(ctx,dx,dy,drawW,drawH,20);ctx.clip();
  ctx.drawImage(img,dx,dy,drawW,drawH); ctx.restore();
  ctx.strokeStyle='#2C2850';ctx.lineWidth=2;roundRect(ctx,dx,dy,drawW,drawH,20);ctx.stroke();
  // body text
  ctx.textAlign='left'; ctx.fillStyle='#F3EFFF'; ctx.font='34px "Shippori Mincho", serif';
  let ty=iy+imgH+gapAfterImg+40;
  for(const ln of lines){ctx.fillText(ln,80,ty);ty+=lineH;}
  // footer
  ctx.textAlign='center';ctx.fillStyle='#A7A1C9';ctx.font='italic 26px "Cormorant Garamond", serif';
  ctx.fillText('— 手のひらの星図で占いました —',W/2,H-50);
  return c;
}
function roundRect(ctx,x,y,w,h,r){ctx.beginPath();ctx.moveTo(x+r,y);ctx.arcTo(x+w,y,x+w,y+h,r);
  ctx.arcTo(x+w,y+h,x,y+h,r);ctx.arcTo(x,y+h,x,y,r);ctx.arcTo(x,y,x+w,y,r);ctx.closePath();}
function wrapJP(ctx,text,maxW){
  const out=[];
  for(const para of text.split('\n')){
    let line='';
    for(const ch of para){
      if(ctx.measureText(line+ch).width>maxW){out.push(line);line=ch;}
      else line+=ch;
    }
    out.push(line);
  }
  return out;
}
 
$('btnSaveImg').onclick=()=>{
  const c=buildPoster(currentHands[activeHand]);
  c.toBlob(b=>{ const a=document.createElement('a');a.href=URL.createObjectURL(b);
