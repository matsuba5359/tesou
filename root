<div class="stars-bg" id="starsBg" aria-hidden="true"></div>
<header class="appbar" id="appbar">
  <button class="appbar-back" id="appBack" aria-label="戻る" type="button">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 5l-7 7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>
  <div class="appbar-brand">手のひらの星図</div>
  <div class="appbar-spacer" aria-hidden="true"></div>
</header>
<div class="wrap">
  <div class="title">
    <div class="kanji">手のひらの星図</div>
    <div class="en">Star Chart of the Palm</div>
  </div>
  <div class="ornament" aria-hidden="true"><span></span><b>✦ ✧ ✦</b><span></span></div>
  <div class="sub">手のひらの写真から、あなたという星座を読み解きます</div>
 
  <!-- ============ TOP / INPUT ============ -->
  <section id="viewTop">
    <div class="panel">
      <div class="btnrow">
        <button class="btn primary" id="btnPick">📷 写真を選ぶ</button>
        <button class="btn" id="btnCam">🎥 カメラで撮る</button>
      </div>
      <input type="file" id="fileInput" accept="image/*" />
      <p class="hint center" style="margin:12px 0 0">正面から・指を軽く開いて・明るい場所で撮ると、よく読めます。</p>
      <div id="topStatus" class="status"></div>
    </div>
 
    <details>
      <summary>使い方とコツ</summary>
